{
	"name": "Parquet_form",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureDataLakeStorage1",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"tableName": {
				"type": "string"
			},
			"runDate": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"folderPath": {
					"value": "@concat(\n    'bronzewa/',\n    dataset().tableName,\n    '/ingestion_year=', formatDateTime(dataset().runDate,'yyyy'),\n    '/ingestion_month=', formatDateTime(dataset().runDate,'MM'),\n    '/ingestion_day=', formatDateTime(dataset().runDate,'dd')\n)",
					"type": "Expression"
				},
				"fileSystem": "raw"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}